# LLM API
LLM_API_KEY=your_deepseek_api_key
LLM_API_URL=https://api.deepseek.com/chat/completions
LLM_MODEL=deepseek-v4-flash

# Optional: only needed after re-enabling semantic_scholar_ai
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# Multi-source configuration
# SOURCE_CONFIG_PATH=./config/sources.json
HOURS_LOOKBACK=168
TOP_N=15
MAX_PER_CATEGORY=5
FEED_CONCURRENCY=10
FEED_TIMEOUT=15
SCORING_BATCH_SIZE=10
SCORING_CONCURRENCY=2
STATE_TTL_DAYS=14
DEBUG_MODE=false
MARKDOWN_OUTPUT_DIR=./data

# Follow Builders integration
FOLLOW_BUILDERS_ENABLED=false
FOLLOW_BUILDERS_MODE=remote
FOLLOW_BUILDERS_SOURCE_CONFIG=./config/follow_builders_sources.json
FOLLOW_BUILDERS_FEED_X_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-x.json
FOLLOW_BUILDERS_FEED_PODCASTS_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-podcasts.json
FOLLOW_BUILDERS_FEED_BLOGS_URL=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main/feed-blogs.json
FOLLOW_BUILDERS_TIME_FILTER_ENABLED=true
FOLLOW_BUILDERS_TWEET_LOOKBACK_HOURS=24
FOLLOW_BUILDERS_BLOG_LOOKBACK_HOURS=72
FOLLOW_BUILDERS_PODCAST_LOOKBACK_HOURS=336
FOLLOW_BUILDERS_MAX_TWEETS_PER_USER=7
FOLLOW_BUILDERS_MAX_ARTICLES_PER_BLOG=3
FOLLOW_BUILDERS_STATE_PATH=./data/follow_builders_seen.json
FOLLOW_BUILDERS_STATE_TTL_DAYS=30
FOLLOW_BUILDERS_OUTPUT_LANG=zh
FOLLOW_BUILDERS_PODCAST_TRANSCRIPT_CHARS=12000
FOLLOW_BUILDERS_BLOG_CONTENT_CHARS=10000
FOLLOW_BUILDERS_CARD_SUMMARY_CHARS=500

# Choose one Feishu delivery mode.

# Option A: group webhook bot
# LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# Option B: self-built app, send directly to a person or a group
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Schedule
SCHEDULE_TIME=09:00
RUN_ON_START=false
